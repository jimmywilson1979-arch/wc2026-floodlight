/* ---------- render: match lab ---------- */
function renderLab(){
  var A=byName($("teamA").value),B=byName($("teamB").value);
  if(!A||!B)return;
  var adj=venueAdj();
  var r=analyse(A.e+adj[0],B.e+adj[1]);
  $("lblA").textContent=A.n+" win";$("lblB").textContent=B.n+" win";
  $("pW").textContent=Math.round(r.w*100);$("pD").textContent=Math.round(r.d*100);$("pL").textContent=Math.round(r.l*100);
  $("foW").textContent=fmtO(fair(r.w));$("foD").textContent=fmtO(fair(r.d));$("foL").textContent=fmtO(fair(r.l));
  $("lamLine").textContent=r.lA.toFixed(2)+"  –  "+r.lB.toFixed(2);
  $("supLine").textContent=(r.lA-r.lB>=0?"+":"")+(r.lA-r.lB).toFixed(2)+" "+A.n;
  $("drLine").textContent=(r.dr+adj[0]-adj[1]>=0?"+":"")+(r.dr+adj[0]-adj[1]);

  // knockout
  if(state.lab.stage==="ko"){
    var advA=r.w+r.d*0.5, advB=r.l+r.d*0.5;
    $("koLine").style.display="block";
    $("koLine").innerHTML='<div class="statline" style="border-top:1px solid var(--line)"><span class="k">To advance (incl. shootout)</span><span>'+
      '<span style="color:var(--gold)">'+A.n+' '+pct(advA)+'</span> · '+B.n+' '+pct(advB)+'</span></div>';
  }else $("koLine").style.display="none";

  // grid
  renderGrid(r);
  // correct scores
  var html="";
  for(var k=0;k<8;k++){var c=r.cs[k];html+='<div class="ln"><span class="s">'+c.i+'–'+c.j+'</span><span>'+pct(c.p)+'</span></div>';}
  $("csList").innerHTML=html;

  // O/U box
  var line=parseFloat($("ouLine").value);
  var ob="";[1.5,2.5,3.5].forEach(function(L){
    var ov=r.ou[L],un=1-ov;
    ob+='<div class="statline"><span class="k">Over / Under '+L.toFixed(1)+'</span><span>'+
      pct(ov)+' <span style="color:var(--muted2)">('+fmtO(fair(ov))+')</span> · '+pct(un)+' <span style="color:var(--muted2)">('+fmtO(fair(un))+')</span></span></div>';
  });
  $("ouBox").innerHTML=ob;
  $("bttsY").textContent=pct(r.bttsY)+"  ("+fmtO(fair(r.bttsY))+")";
  $("bttsN").textContent=pct(r.bttsN)+"  ("+fmtO(fair(r.bttsN))+")";

  renderValue(r,A,B,line);
}
function renderGrid(r){
  var g=r.grid,peak=r.peak,N=6;
  var max=peak.p;
  var h='<table class="sg"><caption>'+"P(score) — "+(r.peak.i)+"–"+(r.peak.j)+" most likely"+'</caption><tr><th></th>';
  for(var j=0;j<=N;j++)h+='<th>'+j+'</th>';h+='</tr>';
  for(var i=0;i<=N;i++){
    h+='<tr><th>'+i+'</th>';
    for(var j2=0;j2<=N;j2++){
      var p=g[i][j2];var op=(0.06+0.94*Math.sqrt(p/max)).toFixed(3);
      var cls=(i===peak.i&&j2===peak.j)?' class="peak"':'';
      h+='<td'+cls+' style="background:rgba(232,178,74,'+op+');color:'+(op>0.5?'#1a1206':'var(--chalk)')+'">'+(p*100<0.5?'':(p*100).toFixed(0))+'</td>';
    }
    h+='</tr>';
  }
  h+='</table>';
  $("sgrid").innerHTML=h;
}
function renderValue(r,A,B,line){
  var comm=(parseFloat($("comm").value)||0)/100;
  var ovL=r.ou[line], unL=1-ovL;
  var rows=[
    {k:A.n+" win",p:r.w,id:"vH"},{k:"Draw",p:r.d,id:"vD"},{k:B.n+" win",p:r.l,id:"vA"},
    {k:"Over "+line.toFixed(1),p:ovL,id:"vO"},{k:"Under "+line.toFixed(1),p:unL,id:"vU"},
    {k:"BTTS Yes",p:r.bttsY,id:"vBY"},{k:"BTTS No",p:r.bttsN,id:"vBN"}
  ];
  var body=$("valBody"),prev={};
  // keep existing odds inputs
  Array.prototype.forEach.call(body.querySelectorAll("input"),function(inp){prev[inp.dataset.id]=inp.value;});
  var h="";
  rows.forEach(function(row){
    h+='<tr><td>'+row.k+'</td><td>'+fmtO(fair(row.p))+'</td>'+
       '<td><input data-id="'+row.id+'" data-p="'+row.p+'" type="number" step="0.01" placeholder="–" value="'+(prev[row.id]||"")+'"></td>'+
       '<td id="ev_'+row.id+'"><span class="badge zero">–</span></td></tr>';
  });
  body.innerHTML=h;
  Array.prototype.forEach.call(body.querySelectorAll("input"),function(inp){
    inp.addEventListener("input",function(){updateEV(this,comm);});
    updateEV(inp,comm);
  });
}
function updateEV(inp,comm){
  var p=parseFloat(inp.dataset.p),o=parseFloat(inp.value),cell=$("ev_"+inp.dataset.id);
  if(!o||o<=1){cell.innerHTML='<span class="badge zero">–</span>';return;}
  var e=ev(p,o,comm);
  var cls=e>0.001?"pos":(e<-0.001?"neg":"zero");
  cell.innerHTML='<span class="badge '+cls+'">'+(e>=0?"+":"")+(e*100).toFixed(1)+'%</span>';
}

