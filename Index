/* ---------- render: ratings ---------- */
var ratSort={key:"elo",dir:-1};
function renderRatings(){
  var q=($("searchT").value||"").toLowerCase();
  var list=state.teams.slice();
  var rankMap={};sortedTeams().forEach(function(t,i){rankMap[t.n]=i+1;});
  list.sort(function(a,b){
    var k=ratSort.key,va,vb;
    if(k==="rank"||k==="elo"){va=a.e;vb=b.e;}
    else if(k==="name"){va=a.n.toLowerCase();vb=b.n.toLowerCase();}
    else{va=a.g;vb=b.g;}
    if(va<vb)return -ratSort.dir;if(va>vb)return ratSort.dir;return 0;
  });
  if(ratSort.key==="rank")list.reverse();
  var h="";
  list.forEach(function(t){
    if(q&&t.n.toLowerCase().indexOf(q)<0)return;
    h+='<tr><td style="color:var(--muted2)">'+rankMap[t.n]+'</td>'+
       '<td class="nm">'+t.n+' <span class="conf">'+t.c+'</span></td>'+
       '<td><span class="gtag">'+t.g+'</span></td>'+
       '<td style="text-align:right"><input class="eloin" type="number" data-n="'+t.n+'" value="'+t.e+'"></td>'+
       '<td><span class="flag '+(t.v?"v":"e")+'">'+(t.v?"✓":"~")+'</span> <button class="btn ghost sm" data-del="'+t.n+'" style="padding:2px 7px;color:var(--muted2)">×</button></td></tr>';
  });
  $("ratBody").innerHTML=h;
  Array.prototype.forEach.call($("ratBody").querySelectorAll("input.eloin"),function(inp){
    inp.addEventListener("change",function(){
      var t=byName(this.dataset.n);if(t){t.e=parseInt(this.value,10)||t.e;t.v=0;save();refreshAll();toast("Updated");}
    });
  });
  Array.prototype.forEach.call($("ratBody").querySelectorAll("[data-del]"),function(btn){
    btn.addEventListener("click",function(){
      if(confirm("Remove "+this.dataset.del+"?")){state.teams=state.teams.filter(function(t){return t.n!==this.dataset.del;}.bind(this));save();refreshAll();}
    });
  });
}

/* ---------- render: results ---------- */
function gMult(gd){if(gd<=1)return 1;if(gd===2)return 1.5;if(gd===3)return 1.75;return 1.75+(gd-3)/8;}

/* name resolution for API feed */
var ALIAS={
 "United States":"USA","United States of America":"USA","USMNT":"USA",
 "Korea Republic":"South Korea","South Korea":"South Korea","Republic of Korea":"South Korea",
 "Turkey":"Türkiye","Turkiye":"Türkiye","Türkiye":"Türkiye",
 "Czech Republic":"Czechia","Czechia":"Czechia",
 "Ivory Coast":"Ivory Coast","Côte d'Ivoire":"Ivory Coast","Cote d'Ivoire":"Ivory Coast","Cote dIvoire":"Ivory Coast",
 "Congo DR":"DR Congo","DR Congo":"DR Congo","Congo-Kinshasa":"DR Congo","Democratic Republic of Congo":"DR Congo","DR Congo (Congo-Kinshasa)":"DR Congo",
 "Curacao":"Curaçao","Curaçao":"Curaçao",
 "Bosnia and Herzegovina":"Bosnia-Herzegovina","Bosnia & Herzegovina":"Bosnia-Herzegovina","Bosnia":"Bosnia-Herzegovina",
 "Cape Verde Islands":"Cape Verde","Cape Verde":"Cape Verde","Cabo Verde":"Cape Verde"
};
function norm(s){return String(s).toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g,"").replace(/[^a-z]/g,"");}
function resolveTeam(apiName){
  if(!apiName)return null;
  if(ALIAS[apiName])return ALIAS[apiName];
  if(byName(apiName))return apiName;
  var k=norm(apiName),map={};
  state.teams.forEach(function(t){map[norm(t.n)]=t.n;});
  if(map[k])return map[k];
  for(var a in ALIAS){if(norm(a)===k)return ALIAS[a];}
  return null;
}
var HOSTS={"USA":1,"Canada":1,"Mexico":1};

/* shared Elo application (manual + API) */
function applyMatch(homeName,awayName,hg,ag,K,adv,fixtureId,source){
  var H=byName(homeName),Aw=byName(awayName);
  if(!H||!Aw||H===Aw)return false;
  var dr=(H.e+adv)-Aw.e;
  var W=hg>ag?1:(hg===ag?0.5:0);
  var g=gMult(Math.abs(hg-ag));
  var change=Math.round(K*g*(W-we(dr)));
  H.e+=change;Aw.e-=change;H.v=0;Aw.v=0;
  state.hist.push({home:H.n,away:Aw.n,hg:hg,ag:ag,dHome:change,dAway:-change,fx:fixtureId||null,src:source||"manual"});
  if(fixtureId)state.applied[fixtureId]=1;
  return change;
}
function renderHist(){
  var box=$("histBox");
  if(!state.hist.length){box.innerHTML='<div class="empty">No results logged yet.</div>';$("undoRes").style.display="none";$("clearRes").style.display="none";$("histCount").textContent="";return;}
  $("undoRes").style.display="inline-block";$("clearRes").style.display="inline-block";$("histCount").textContent=state.hist.length+" logged";
  var h="";
  for(var i=state.hist.length-1;i>=0;i--){
    var m=state.hist[i];
    var da=(m.dHome>=0?'<span class="up">+'+m.dHome+'</span>':'<span class="dn">'+m.dHome+'</span>');
    var db=(m.dAway>=0?'<span class="up">+'+m.dAway+'</span>':'<span class="dn">'+m.dAway+'</span>');
    var tag=(m.src==="api")?' <span style="color:var(--muted2);font-size:10px">API</span>':'';
    h+='<div class="h"><span class="res">'+m.home+' '+m.hg+'–'+m.ag+' '+m.away+tag+'</span>'+
       '<span class="dl">'+da+' / '+db+'</span></div>';
  }
  box.innerHTML=h;
}
function applyResult(){
  var H=byName($("rHome").value),Aw=byName($("rAway").value);
  if(!H||!Aw||H===Aw){toast("Pick two different teams");return;}
  var hg=parseInt($("rHg").value,10)||0,ag=parseInt($("rAg").value,10)||0;
  var K=parseInt($("rK").value,10);
  var adv=(state.lab._rv==="H")?state.model.adv:0;
  var change=applyMatch(H.n,Aw.n,hg,ag,K,adv,null,"manual");
  save();refreshAll();toast(H.n+" "+(change>=0?"+":"")+change);
}
function undoResult(){
  var m=state.hist.pop();if(!m)return;
  var H=byName(m.home),Aw=byName(m.away);
  if(H)H.e-=m.dHome;if(Aw)Aw.e-=m.dAway;
  if(m.fx&&state.applied)delete state.applied[m.fx];
  save();refreshAll();toast("Undone");
}
function clearResults(){
  if(!confirm("Clear all logged results and reset Elo to the seed?"))return;
  state.hist=[];state.applied={};
  state.teams=SEED.map(function(x){return{n:x.n,g:x.g,c:x.c,e:x.e,v:x.v};});
  save();refreshAll();toast("Cleared");
}
function syncResults(){
  var btn=$("syncBtn"),note=$("syncNote");
  btn.disabled=true;var orig=btn.textContent;btn.textContent="Syncing…";
  fetch("/.netlify/functions/wc-results").then(function(r){
    return r.text().then(function(txt){
      var j;try{j=JSON.parse(txt);}catch(e){throw new Error("HTTP "+r.status+" "+txt.slice(0,100));}
      if(!r.ok||!j.fixtures)throw new Error(j.error||("HTTP "+r.status));
      return j;
    });
  }).then(function(j){
    var fx=j.fixtures.slice().sort(function(a,b){return a.ts-b.ts;});
    var applied=0,unmatched=[],hostOn=$("hostAdv").checked;
    fx.forEach(function(f){
      if(state.applied[f.id])return;
      var hn=resolveTeam(f.home),an=resolveTeam(f.away);
      if(!hn||!an){unmatched.push((hn?f.away:f.home));return;}
      var adv=(hostOn&&HOSTS[hn])?state.model.adv:0;
      applyMatch(hn,an,f.hg,f.ag,60,adv,f.id,"api");applied++;
    });
    save();refreshAll();
    var msg=applied?("Synced "+applied+" new result"+(applied>1?"s":"")):"No new finished matches";
    toast(msg);
    note.innerHTML=msg+" · "+j.count+" finished upstream."+(unmatched.length?(" <span style=\"color:var(--neg)\">Unmatched: "+unmatched.join(", ")+" — add an alias or rename in Ratings.</span>"):"");
  }).catch(function(e){
    note.innerHTML="<span style=\"color:var(--neg)\">Sync failed:</span> "+e.message+" — live only once deployed to Netlify with APIFOOTBALL_KEY set.";
  }).then(function(){btn.disabled=false;btn.textContent=orig;});
}

