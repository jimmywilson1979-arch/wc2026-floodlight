    st.forEach(function(t){var o=document.createElement("option");o.value=t.n;o.textContent=t.n+"  ("+t.e+")";el.appendChild(o);});
    if(cur)el.value=cur;
  });
}
function initLabSelects(){
  fillSelect("teamA","teamB");
