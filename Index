function save(){try{LS.setItem("wc26_teams",JSON.stringify(state.teams));LS.setItem("wc26_hist",JSON.stringify(state.hist));LS.setItem("wc26_model",JSON.stringify(state.model));LS.setItem("wc26_applied",JSON.stringify(state.applied));}catch(e){}}
function load(){
  var t=null,h=null,m=null,ap=null;
  try{t=JSON.parse(LS.getItem("wc26_teams"));h=JSON.parse(LS.getItem("wc26_hist"));m=JSON.parse(LS.getItem("wc26_model"));ap=JSON.parse(LS.getItem("wc26_applied"));}catch(e){}
  state.teams=(t&&t.length)?t:SEED.map(function(x){return{n:x.n,g:x.g,c:x.c,e:x.e,v:x.v};});
  state.hist=h||[];
  state.applied=ap||{};
  state.model=m||{mu:2.6,div:160,adv:100};
}
var state={teams:[],hist:[],model:{mu:2.6,div:160,adv:100},applied:{},lab:{a:0,b:1,venue:"N",stage:"group"}};

/* ---------- math ---------- */
var FACT=[1];for(var i=1;i<=12;i++)FACT[i]=FACT[i-1]*i;
function pois(k,l){return Math.exp(-l)*Math.pow(l,k)/FACT[k];}
function we(dr){return 1/(Math.pow(10,-dr/400)+1);}
function lambdas(eA,eB){
  var dr=eA-eB;
  var cl=Math.max(-480,Math.min(480,dr));
  var sup=cl/state.model.div;
  return[Math.max(0.35,state.model.mu/2+sup/2),Math.max(0.35,state.model.mu/2-sup/2)];
}
var MAXG=10;
function grid(lA,lB){
  var g=[],pa=[],pb=[];
  for(var k=0;k<=MAXG;k++){pa[k]=pois(k,lA);pb[k]=pois(k,lB);}
  for(var i=0;i<=MAXG;i++){g[i]=[];for(var j=0;j<=MAXG;j++)g[i][j]=pa[i]*pb[j];}
  return g;
}
function analyse(eA,eB){
  var ls=lambdas(eA,eB),g=grid(ls[0],ls[1]);
  var w=0,d=0,l=0,bttsY=0,peak={p:-1,i:0,j:0},cs=[];
  var ou={};[0.5,1.5,2.5,3.5,4.5].forEach(function(L){ou[L]=0;});
  for(var i=0;i<=MAXG;i++)for(var j=0;j<=MAXG;j++){
    var p=g[i][j];
    if(i>j)w+=p;else if(i===j)d+=p;else l+=p;
    if(i>=1&&j>=1)bttsY+=p;
    var tot=i+j;[0.5,1.5,2.5,3.5,4.5].forEach(function(L){if(tot>L)ou[L]+=p;});
    if(p>peak.p)peak={p:p,i:i,j:j};
    if(i<=6&&j<=6)cs.push({i:i,j:j,p:p});
  }
  cs.sort(function(a,b){return b.p-a.p;});
  return{lA:ls[0],lB:ls[1],w:w,d:d,l:l,bttsY:bttsY,bttsN:1-bttsY,ou:ou,peak:peak,cs:cs,grid:g,dr:eA-eB};
}
function ev(p,odds,comm){if(!odds||odds<=1)return null;return p*(odds-1)*(1-comm)-(1-p);}
function fair(p){return p>0?(1/p):Infinity;}
function fmtO(x){return(x===Infinity||!isFinite(x))?"–":x.toFixed(2);}
function pct(x){return(x*100).toFixed(1)+"%";}

/* ---------- helpers ---------- */
function byName(n){for(var i=0;i<state.teams.length;i++)if(state.teams[i].n===n)return state.teams[i];return null;}
function sortedTeams(){return state.teams.slice().sort(function(a,b){return b.e-a.e;});}
function $(id){return document.getElementById(id);}
function venueAdj(){
  var a=0,b=0,adv=state.model.adv;
  if(state.lab.venue==="A")a=adv;else if(state.lab.venue==="B")b=adv;
  return[a,b];
}
function toast(m){var t=$("toast");t.textContent=m;t.className="toast show";setTimeout(function(){t.className="toast";},1400);}

